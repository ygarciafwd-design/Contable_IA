# =============================================
# ASISTENTE CONTABLE IA v2 — CONFIGURACIÓN
# =============================================

# ── Servidor ──────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# ── Base de datos MySQL ───────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=contable_ia
DB_USER=root
DB_PASSWORD=1234

# ── JWT ───────────────────────────────────────
JWT_SECRET=tu_clave_secreta_super_segura_aqui_cambiar_en_produccion
JWT_EXPIRES_IN=4h

# ── Anthropic API (Claude — OCR de facturas) ──
ANTHROPIC_API_KEY=tu_api_key_de_anthropic_aqui

# ── Google OAuth2 (Drive + Gmail MCP) ─────────
# Obtén estas credenciales en: https://console.cloud.google.com
# Scopes necesarios:
#   https://www.googleapis.com/auth/drive.readonly
#   https://www.googleapis.com/auth/gmail.readonly
GOOGLE_CLIENT_ID=tu_google_client_id_aqui
GOOGLE_CLIENT_SECRET=tu_google_client_secret_aqui
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback
GOOGLE_REFRESH_TOKEN=tu_refresh_token_aqui

# ── Scheduler (procesador de facturas) ────────
# Intervalo en ms entre ciclos (default: 40000 = 40 segundos)
CRON_INTERVAL_MS=40000

# ── CORS ──────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Text-to-Speech (opcional) ─────────────────
TTS_ENABLED=true
